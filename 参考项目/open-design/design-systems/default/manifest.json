      {
        "path": "preview/typography.html",
        "role": "typography",
        "title": "Typography"
      },
      {
        "path": "preview/spacing.html",
        "role": "spacing",
        "title": "Spacing"
      },
      {
        "path": "preview/components-buttons.html",
        "role": "buttons",
        "title": "Buttons"
      },
      {
        "path": "preview/components-inputs.html",
        "role": "inputs",
        "title": "Inputs"
      },
      {
        "path": "preview/app.html",
        "role": "app",
        "title": "App Preview"
      }
    ]
