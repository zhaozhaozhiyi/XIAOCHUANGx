{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "video-template-hunched-character-animation",
  "title": "Hunched Character Animation",
  "version": "0.1.0",
  "description": "Instruction for Seedance 2 to create an in-place walking animation for a specific character reference.",
  "license": "CC-BY-4.0",
  "author": {
    "name": "Olivio Sarikas",
    "url": "https://x.com/OlivioSarikas/status/2049093747011670042"
  },
  "homepage": "https://github.com/YouMind-OpenLab/awesome-seedance-2-prompts",
  "tags": [
    "video-template",
    "first-party",
    "video",
    "general"
  ],
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "video",
    "scenario": "video",
    "surface": "video",
    "preview": {
      "type": "video",
      "poster": "https://customer-qs6wnyfuv0gcybzj.cloudflarestream.com/d3d5dcaf102414a8cceca23d60b5c0d0/thumbnails/thumbnail.jpg",
      "video": "https://customer-qs6wnyfuv0gcybzj.cloudflarestream.com/d3d5dcaf102414a8cceca23d60b5c0d0/downloads/default.mp4"
    },
    "useCase": {
      "query": {
        "en": "create a walking animation for this hunched over character. the character stays in place",
        "zh-CN": "使用这个插件完成以下任务：create a walking animation for this hunched over character. the character stays in place"
      }
    },
    "inputs": [
      {
        "name": "model",
        "label": "Model",
        "type": "select",
        "options": [
          "seedance-2.0"
        ],
        "default": "seedance-2.0"
      },
      {
        "name": "aspect",
        "label": "Aspect ratio",
        "type": "select",
        "options": [
          "16:9",
          "9:16",
          "1:1",
          "4:5"
        ],
        "default": "16:9"
      }
    ],
    "context": {
      "assets": [
        "./template.json"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "video-generate"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "media:video-generate"
    ]
  }
}
