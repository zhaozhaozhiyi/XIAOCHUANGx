{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "video-template-animation-transfer-and-camera-tracking-prompt",
  "title": "Animation transfer and camera tracking prompt",
  "version": "0.1.0",
  "description": "A technical prompt for Seedance 2.0 that applies a specific motion reference to a character while maintaining fixed camera tracking.",
  "license": "CC-BY-4.0",
  "author": {
    "name": "Olivio Sarikas",
    "url": "https://x.com/OlivioSarikas/status/2049093762077630628"
  },
  "homepage": "https://github.com/YouMind-OpenLab/awesome-seedance-2-prompts",
  "tags": [
    "video-template",
    "first-party",
    "video",
    "general"
  ],
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "video",
    "scenario": "video",
    "surface": "video",
    "preview": {
      "type": "video",
      "poster": "https://customer-qs6wnyfuv0gcybzj.cloudflarestream.com/089e7cd70d20131d6d1b44741520eaee/thumbnails/thumbnail.jpg",
      "video": "https://customer-qs6wnyfuv0gcybzj.cloudflarestream.com/089e7cd70d20131d6d1b44741520eaee/downloads/default.mp4"
    },
    "useCase": {
      "query": {
        "en": "apply the walking animation of @anim exactly as it is to @char7. the camera tracks the character exactly in place, camera angle does not change",
        "zh-CN": "使用这个插件完成以下任务：apply the walking animation of @anim exactly as it is to @char7. the camera tracks the character exactly in place, camera angle does not change"
      }
    },
    "inputs": [
      {
        "name": "model",
        "label": "Model",
        "type": "select",
        "options": [
          "seedance-2.0"
        ],
        "default": "seedance-2.0"
      },
      {
        "name": "aspect",
        "label": "Aspect ratio",
        "type": "select",
        "options": [
          "16:9",
          "9:16",
          "1:1",
          "4:5"
        ],
        "default": "16:9"
      }
    ],
    "context": {
      "assets": [
        "./template.json"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "video-generate"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "media:video-generate"
    ]
  }
}
