{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "od-react-export",
  "title": "Export to React",
  "version": "0.1.0",
  "description": "Starter downstream export plugin for turning an accepted Open Design artifact into a React component handoff.",
  "license": "MIT",
  "author": {
    "name": "Open Design",
    "url": "https://github.com/nexu-io"
  },
  "homepage": "https://github.com/nexu-io/open-design/tree/main/plugins/_official/scenarios/od-react-export",
  "tags": [
    "scenario",
    "first-party",
    "export",
    "downstream",
    "handoff",
    "react",
    "reactjs"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "tune-collab",
    "scenario": "downstream-export",
    "mode": "export",
    "pipeline": {
      "stages": [
        {
          "id": "handoff",
          "atoms": [
            "handoff"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:read",
      "fs:write"
    ],
    "useCase": {
      "query": {
        "en": "Export the accepted Open Design artifact to a React 18 + TypeScript component. Preserve the visual system, extract reusable props only where they clarify intent, and finish with integration notes.",
        "zh-CN": "将已确认的 Open Design 产物导出为 React 18 + TypeScript 组件。保持视觉系统一致，只在有助于表达意图时抽出可复用 props，并在最后给出集成说明。"
      },
      "exampleOutputs": []
    },
    "inputs": [
      {
        "name": "componentName",
        "type": "string",
        "required": false,
        "label": "Component name",
        "placeholder": "LandingHero"
      },
      {
        "name": "styling",
        "type": "select",
        "required": false,
        "label": "Styling",
        "options": [
          "Tailwind CSS",
          "CSS module",
          "plain CSS"
        ],
        "default": "Tailwind CSS"
      }
    ]
  }
}
