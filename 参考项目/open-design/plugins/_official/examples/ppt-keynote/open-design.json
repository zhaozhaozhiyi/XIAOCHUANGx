{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "example-ppt-keynote",
  "title": "Keynote 风格 PPT",
  "version": "0.1.0",
  "description": "苹果 Keynote 级别幻灯片, 一屏一卡, 键盘左右切换",
  "license": "MIT",
  "author": {
    "name": "Open Design",
    "url": "https://github.com/nexu-io"
  },
  "homepage": "https://github.com/nexu-io/open-design/tree/main/plugins/_official/examples/ppt-keynote",
  "tags": [
    "example",
    "first-party",
    "deck",
    "marketing",
    "web",
    "slides",
    "presentation",
    "untitled"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "deck",
    "scenario": "marketing",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": "用「Keynote 风格 PPT」模板把我的内容做成一套「苹果 Keynote 级别幻灯片, 一屏一卡, 键盘左右切换」。保持模板的视觉签名，使用真实内容和数据，避免 lorem ipsum 和占位图片。",
      "exampleOutputs": [
        {
          "path": "./example.html",
          "title": "Keynote 风格 PPT"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "assets": [
        "./example.html"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ]
  }
}
