{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "example-frame-flowchart-sticky",
  "title": "便利贴流程图帧",
  "version": "0.1.0",
  "description": "SVG 曲线连接 + 便利贴节点 + 光标交互, 像白板 brainstorm",
  "license": "MIT",
  "author": {
    "name": "Open Design",
    "url": "https://github.com/nexu-io"
  },
  "homepage": "https://github.com/nexu-io/open-design/tree/main/plugins/_official/examples/frame-flowchart-sticky",
  "tags": [
    "example",
    "first-party",
    "video",
    "operations",
    "flowchart",
    "diagram",
    "sticky",
    "whiteboard",
    "frame"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "video",
    "scenario": "operations",
    "surface": "video",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": "用「便利贴流程图帧」模板把我的内容做成一段「SVG 曲线连接 + 便利贴节点 + 光标交互, 像白板 brainstorm」。保持模板的视觉签名，使用真实内容和数据，避免 lorem ipsum 和占位图片。",
      "exampleOutputs": [
        {
          "path": "./example.html",
          "title": "便利贴流程图帧"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "assets": [
        "./example.html"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ]
  }
}
