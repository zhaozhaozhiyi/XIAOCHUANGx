{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "example-digital-eguide",
  "title": "Digital Eguide",
  "version": "0.1.0",
  "description": "A two-spread digital e-guide preview — page 1 is a cover (display title,\nauthor, \"What's inside\" stats, table of contents teaser); page 2 is a\nspread (lesson body with pull-quote and a step list). Lifestyle / creator\nbrand tone. Use when the brief asks for an \"e-guide\", \"digital guide\",\n\"lookbook\", \"lead magnet\", \"creator guide\", \"playbook\", \"PDF guide\",\nor \"电子指南\".",
  "license": "MIT",
  "author": {
    "name": "Open Design",
    "url": "https://github.com/nexu-io"
  },
  "homepage": "https://github.com/nexu-io/open-design/tree/main/plugins/_official/examples/digital-eguide",
  "tags": [
    "example",
    "first-party",
    "prototype",
    "marketing",
    "web",
    "desktop",
    "e-guide",
    "digital-guide",
    "lead-magnet",
    "lookbook",
    "creator-guide",
    "playbook",
    "pdf-guide",
    "ebook",
    "untitled"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "platform": "desktop",
    "scenario": "marketing",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Design 'The Creator's Style & Format Guide' — cover page and one inside spread, lifestyle creator brand.",
        "zh-CN": "使用这个插件完成以下任务：Design 'The Creator's Style & Format Guide' — cover page and one inside spread, lifestyle creator brand."
      },
      "exampleOutputs": [
        {
          "path": "./example.html",
          "title": "Digital Eguide"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "craft": [
        "typography",
        "typography-hierarchy",
        "typography-hierarchy-editorial",
        "rtl-and-bidi"
      ],
      "assets": [
        "./example.html"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ]
  }
}
