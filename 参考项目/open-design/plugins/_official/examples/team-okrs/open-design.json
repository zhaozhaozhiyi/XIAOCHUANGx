{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "example-team-okrs",
  "title": "Team Okrs",
  "version": "0.1.0",
  "description": "OKR tracker page — quarter banner, three objectives with their key\nresults as progress bars, owner avatars, status pills, and a \"this\nquarter at a glance\" sidebar. Use when the brief mentions \"OKRs\",\n\"key results\", \"objectives\", or \"目标\".",
  "license": "MIT",
  "author": {
    "name": "Open Design",
    "url": "https://github.com/nexu-io"
  },
  "homepage": "https://github.com/nexu-io/open-design/tree/main/plugins/_official/examples/team-okrs",
  "tags": [
    "example",
    "first-party",
    "prototype",
    "product",
    "web",
    "desktop",
    "okr",
    "okrs",
    "key-results",
    "objectives",
    "untitled"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "prototype",
    "platform": "desktop",
    "scenario": "product",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./example.html"
    },
    "useCase": {
      "query": {
        "en": "Build an OKR tracker for Q4 — three objectives, three key results each, progress bars, owners, status pills.",
        "zh-CN": "使用这个插件完成以下任务：Build an OKR tracker for Q4 — three objectives, three key results each, progress bars, owners, status pills."
      },
      "exampleOutputs": [
        {
          "path": "./example.html",
          "title": "Team Okrs"
        }
      ]
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "designSystem": {
        "primary": true
      },
      "assets": [
        "./example.html"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ]
  }
}
