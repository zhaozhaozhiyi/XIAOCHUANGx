{
  "name": "web",
  "version": "0.1.2-alpha",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "pnpm --filter @jlc/contracts build && pnpm --filter @jlc/runtime-core build",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "node -e \"const fs=require('fs');const p=require('path');fs.copyFileSync(p.join('node_modules','pdfjs-dist','build','pdf.worker.min.mjs'),p.join('public','pdf.worker.min.mjs'));\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@jlc/contracts": "workspace:*",
    "@jlc/runtime-core": "workspace:*",
    "@jvmr/pptx-to-html": "^1.0.1",
    "docx-preview": "^0.3.7",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "next": "16.2.6",
    "pdfjs-dist": "5.3.93",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
