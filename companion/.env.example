# 监听（仅 loopback）
COMPANION_HOST=127.0.0.1
COMPANION_PORT=9477

# simulate | spawn | cli（默认 cli：真实 Agent CLI）
COMPANION_RUN_MODE=cli

# cli 失败时：error（默认，联调）| simulate（无 CLI 时演示 UI）
COMPANION_CLI_FALLBACK=error

COMPANION_DEFAULT_AGENT=codex

# Hermes agentId 时优先走 Gateway（与 web HERMES_API_URL 一致）
# HERMES_API_URL=http://127.0.0.1:8642
# HERMES_API_KEY=
# HERMES_MODEL=hermes-agent
# COMPANION_HERMES_GATEWAY=true

# Skill 根目录（默认：仓库 skills/；交付时可指向客户定制目录）
# JLC_SKILLS_DIR=/path/to/custom-skills
# COMPANION_DATA_DIR=~/.jlcresearch/companion
# COMPANION_API_TOKEN=
