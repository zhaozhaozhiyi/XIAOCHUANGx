# 服务
PORT=3001
NODE_ENV=development
API_PREFIX=v1

# PostgreSQL（与 docker-compose.yml 默认一致）
DATABASE_URL="postgresql://jlc:jlc_dev@localhost:5432/jlc?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# 会话 JWT（生产务必更换为强随机串）
SESSION_SECRET="change-me-in-production-use-openssl-rand"

# 开发：固定验证码 123456，跳过真实短信
AUTH_DEV_MODE=true
AUTH_OTP_FIXED=123456
AUTH_OTP_TTL_SECONDS=300
AUTH_OTP_RESEND_SECONDS=60
AUTH_OTP_DAILY_LIMIT=10
AUTH_SESSION_TTL_SECONDS=604800

# CORS（Next.js BFF / 本地 Web）
CORS_ORIGINS=http://localhost:3000
